{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/ja/app",
        "destination": "/app/index.html"
      },
      {
        "source": "/ja/app/**",
        "destination": "/app/index.html"
      },
      {
        "source": "/en/app",
        "destination": "/app/index.html"
      },
      {
        "source": "/en/app/**",
        "destination": "/app/index.html"
      },
      {
        "source": "/ja",
        "destination": "/ja/index.html"
      },
      {
        "source": "/en",
        "destination": "/en/index.html"
      }
    ]
  }
}
